{
    "name": "zod-inscribe",
    "version": "0.1.0",
    "description": "Turns zod schemas into code.",
    "main": "dist/lib/index.js",
    "repository": {
        "type": "git",
        "url": "https://www.github.com/GregRos/zod-inscribe"
    },
    "author": "GregRos",
    "license": "MIT",
    "keywords": [
        "",
        "zod-to-ts"
    ],
    "scripts": {
        "build": "tsc -b tsconfig.all.json",
        "clean": "shx rm -rf dist",
        "rebuild": "run-s clean build",
        "prettier:fix": "prettier -w src/**/*.ts",
        "prettier": "prettier --check 'src/**/*.ts'",
        "eslint": "eslint 'src/**/*.ts'",
        "eslint:fix": "eslint --fix src/**/*.ts",
        "lint:check": "run-s -c prettier eslint",
        "lint:fix": "run-s prettier:fix eslint:fix",
        "docs": "node dist/generate-docs/run.js"
    },
    "dependencies": {
        "base64-js": "^1.5.1",
        "parjs": "^0.16.1",
        "ts-node": "^10.9.1",
        "zod": "^3.21.4"
    },
    "devDependencies": {
        "@gregros/eslint-config": "^0.4.0",
        "@types/lodash": "^4.14.185",
        "@types/node": "^17.0.45",
        "@typescript-eslint/eslint-plugin": "^6.5.0",
        "@typescript-eslint/parser": "^6.5.0",
        "eslint": "^8.8.0",
        "lodash": "^4.17.21",
        "npm-run-all": "^4.1.5",
        "nyc": "^15.0.0",
        "prettier": "^3.0.3",
        "shx": "^0.3.3",
        "source-map-support": "^0.5.21",
        "tsconfig-paths": "^3.14.1",
        "typescript": "^5.2.2"
    },
    "nyc": {
        "produce-source-map": true,
        "extension": [
            ".ts",
            ".js"
        ],
        "reporter": [
            "lcov",
            "text",
            "text-summary",
            "html"
        ],
        "include": [
            "src/lib/**/*.ts",
            "dist/lib/**/*.js"
        ],
        "all": true,
        "sourceMap": true
    },
    "ava": {
        "workerThreads": false,
        "typescript": {
            "rewritePaths": {
                "src/": "dist/"
            },
            "compile": false
        },
        "extensions": [],
        "files": [
            "src/test/tests/**/*.ts"
        ],
        "require": [
            "./dist/test/setup.js"
        ],
        "timeout": "30s"
    }
}
